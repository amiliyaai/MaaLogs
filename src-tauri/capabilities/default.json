{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-size",
    "core:window:allow-center",
    "opener:default",
    "updater:default",
    "process:default",
    "store:default",
    "dialog:default",
    {
      "identifier": "fs:default"
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "D:/**" },
        { "path": "C:/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "D:/**" },
        { "path": "C:/**" }
      ]
    },
    "fs:allow-exists",
    "fs:allow-write-text-file",
    "fs:allow-write-file",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-applog-read",
    "fs:allow-applog-read-recursive",
    "fs:allow-applog-write",
    "fs:allow-applog-write-recursive",
    "fs:allow-applog-meta",
    "fs:allow-applog-meta-recursive",
    "fs:allow-appcache-read",
    "fs:allow-appcache-read-recursive",
    "fs:allow-appcache-write",
    "fs:allow-appcache-write-recursive",
    "fs:allow-appcache-meta",
    "fs:allow-appcache-meta-recursive"
  ]
}
